  "bandwidth_mbps_list": [1, 2, 5, 10],
  "strategies": ["ours", "cloud_condition"],
  "steps": 30,
  "guidance_scale": 7.5,
  "seed": 42,
  "rtt_ms": 20.0,
  "baseline_image_format": "PNG",
  "baseline_jpeg_quality": 95
}
